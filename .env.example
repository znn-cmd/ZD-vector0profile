# ZIMA Dubai Vector Profile вЂ” Environment Variables
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

# App Mode: "mock" (default, no external services) or "live" (Google Sheets + Drive)
NEXT_PUBLIC_APP_MODE=mock

# Base URL вЂ” used for invite links and report URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# в”Ђв”Ђв”Ђ Google Sheets + Drive (required for live mode) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
